#
#   2. Use with iptables/ip6tables:
#      ip6tables -I OUTPUT -m set --match-set blacklist-vk-v6 dst -j REJECT
#      ip6tables -I FORWARD -m set --match-set blacklist-vk-v6 dst -j REJECT
#
#   3. To flush/delete the set:
